# Tier 3: Registry
# ================================================================
println("");
println("--- tier 3: registry ---");

b = bench_new("registry/all_profiles");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { all_profiles(); }
bench_batch_stop(b, N);
