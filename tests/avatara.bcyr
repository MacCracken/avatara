b = bench_new("registry/lookup_by_name");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { lookup("Krishna"); }
bench_batch_stop(b, N);
bench_report(b);

b = bench_new("registry/query_courage_0.9");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { query_min_trait(PROF_COURAGE, 0.9); }
bench_batch_stop(b, N);
bench_report(b);

b = bench_new("registry/by_tradition");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { by_tradition("Norse"); }
bench_batch_stop(b, N);
bench_report(b);

# ================================================================
# Tier 4: Compose
# ================================================================
println("");
println("--- tier 4: compose ---");

var tip = kabbalah_tiphareth();
var vish = hindu_vishnu();
var ath = olympian_athena();

b = bench_new("compose/three_traditions");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) {
    var w = vec_new();
    vec_push(w, weighted_new(tip, 1.0));
    vec_push(w, weighted_new(vish, 0.8));
    vec_push(w, weighted_new(ath, 0.6));
    compose(w);
}
bench_batch_stop(b, N);
bench_report(b);

# ================================================================
# Tier 5: History
# ================================================================
println("");
println("--- tier 5: history ---");

b = bench_new("history/context_for_tradition");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { context_for_tradition("Hindu"); }
bench_batch_stop(b, N);
bench_report(b);

b = bench_new("history/context_all_traditions");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) {
    var mt = mapped_traditions();
    for (var j = 0; j < vec_len(mt); j = j + 1) {
        context_for_tradition(vec_get(mt, j));
    }
}
bench_batch_stop(b, N);
bench_report(b);

b = bench_new("history/traditions_for_civ");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { traditions_for_civilization("Indus Valley"); }
bench_batch_stop(b, N);
bench_report(b);

b = bench_new("history/traditions_for_era");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { traditions_for_era("Tang Dynasty"); }
bench_batch_stop(b, N);
bench_report(b);

b = bench_new("history/traditions_active_at");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { traditions_active_at((0-500)); }
bench_batch_stop(b, N);
bench_report(b);

b = bench_new("history/query_civilization");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { query_civilization("Ancient Greece"); }
bench_batch_stop(b, N);
bench_report(b);

# ================================================================
# Tier 6: Affinity
# ================================================================
println("");
println("--- tier 6: affinity ---");

var aff_a = kabbalah_tiphareth();
var aff_b = norse_thor();

b = bench_new("affinity/score_pair");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { affinity(aff_a, aff_b); }
bench_batch_stop(b, N);
bench_report(b);

b = bench_new("affinity/similar_to_5");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { similar_to(aff_a, 5); }
bench_batch_stop(b, N);
bench_report(b);

b = bench_new("affinity/cross_tradition_match");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { cross_tradition_match(aff_b); }
bench_batch_stop(b, N);
bench_report(b);

b = bench_new("affinity/detect_conflicts");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { detect_conflicts(kabbalah_gevurah(), kabbalah_chesed()); }
bench_batch_stop(b, N);
bench_report(b);

