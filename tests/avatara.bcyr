var N = 1000;
var b = 0;

alloc_init();
println("=== avatara benchmarks (39 benches) ===");

# ================================================================
# Tier 1: Single profile creation
# ================================================================
println("");
println("--- tier 1: single profile ---");

b = bench_new("kabbalah/single_profile");
bench_batch_start(b);
for (var i = 0; i < N; i = i + 1) { kabbalah_tiphareth(); }
bench_batch_stop(b, N);
bench_report(b);

