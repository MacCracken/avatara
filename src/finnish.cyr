    var p = profile_new();
    store64(p + PROF_NAME, "Marjatta");
    store64(p + PROF_TRADITION, "Finnish");
    store64(p + PROF_DESC, "Virgin mother of the new king — she who ate a lingonberry and bore a holy child, ending the age of Väinämöinen");
