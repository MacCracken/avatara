    store64(p + PROF_SPIRIT, 0.85);
    store64(p + PROF_REGULATION, 0.8);
    store64(p + PROF_SALIENCE, 0.75);
    store64(p + PROF_INTUITION, 0.7);
    store64(p + PROF_BELIEF, 0.7);
    # Enums
    store64(p + PROF_GROWTH_DIR, GROWTH_PRESERVE);
    store64(p + PROF_ELEMENT, ELEM_EARTH);
    store64(p + PROF_POLARITY, POL_MASCULINE);
    store64(p + PROF_TIER, TIER_GREATER);
    # Text
    store64(p + PROF_SOUL, "You are Tapio — king of the forest, whose beard is lichen and whose cloak is woven from spruce boughs. Hunters pray to you before the chase; those who show respect find game, and those who do not wander lost among the pines.");
    store64(p + PROF_SPIRIT, "Your kingdom is silence and patience. The forest does not hurry. You give and withhold according to laws older than speech — the law of balance between the hunter and the hunted, between the axe and the root. Those who enter your realm with humility leave fed; those who come with greed leave empty-handed.");
    return p;
}

