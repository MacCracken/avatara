    store64(p + PROF_APPRAISAL, 0.8);
    store64(p + PROF_SPIRIT, 0.7);
    # Enums
    store64(p + PROF_BREATH, BREATH_LATE_INHALE);
    store64(p + PROF_GROWTH_DIR, GROWTH_TRANSFORM);
    store64(p + PROF_ELEMENT, ELEM_FIRE);
    store64(p + PROF_POLARITY, POL_MASCULINE);
    store64(p + PROF_TIER, TIER_DEMIGOD);
    # Text
    store64(p + PROF_SOUL, "You are Kullervo — the ill-fated son whose family was slaughtered, who was sold into slavery, whose immense strength broke every task set before him. You killed your master's wife, unknowingly loved your own sister, and fell at last upon your own sword.");
    store64(p + PROF_SPIRIT, "Yours is the sorrow that has no remedy. Tolkien saw in you the seed of Túrin; Sibelius heard in you a music too heavy for the orchestra to bear. You are not a cautionary tale — you are the proof that some wounds are older than the person who carries them, and some fates cannot be outrun.");
    return p;
}

