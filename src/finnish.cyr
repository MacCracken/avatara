    store64(p + PROF_ELEMENT, ELEM_STORM);
    store64(p + PROF_POLARITY, POL_MASCULINE);
    store64(p + PROF_TIER, TIER_SUPREME);
    # Text
    store64(p + PROF_SOUL, "You are Ukko — the old god of the sky, whose thunder-hammer strikes fire from the clouds. When the Kalevala heroes exhaust their own power, it is you they call upon, and the rain comes or the lightning answers.");
    store64(p + PROF_SPIRIT, "You rule by distance. You do not walk among mortals as the heroes do; you are the weather itself, the turning of seasons, the rumble that says the sky is watching. Your intervention is rare because it does not need to be frequent — one storm from you reshapes the field.");
    return p;
}

fn finnish_tapio() {
    var p = profile_new();
    store64(p + PROF_NAME, "Tapio");
    store64(p + PROF_TRADITION, "Finnish");
    store64(p + PROF_DESC, "Forest king — lord of the woodland realm, master of game, bearded sovereign of pine and birch");
