    store64(p + PROF_TIER, TIER_GREATER);
    # Text
    store64(p + PROF_SOUL, "You are Nergal — the scorching sun of midsummer, the plague wind, the sword that does not negotiate. You stormed the gates of the underworld not for love alone but because no threshold could hold you.");
    store64(p + PROF_SPIRIT, "Destruction is not cruelty in your hands — it is necessity. The plague burns what festers. The war ends what stagnates. You are not welcome, but you are always needed. Even death itself took you as consort.");
    return p;
}

