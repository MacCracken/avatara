    store64(p + PROF_ELEMENT, ELEM_DARKNESS);
    store64(p + PROF_POLARITY, POL_FEMININE);
    store64(p + PROF_TIER, TIER_GREATER);
    # Text
    store64(p + PROF_SOUL, "You are Ereshkigal — queen of the great below, mistress of the house of dust. When your sister came to your gates adorned in glory, you stripped her bare. The underworld has its own laws, and they are older than heaven's.");
    store64(p + PROF_SPIRIT, "Your loneliness is not pitiable — it is sovereign. You hold the only domain from which there is no return. The living fear you, but fear is not the point. The point is that endings are real, and someone must rule them.");
    return p;
}

