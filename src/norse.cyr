    store64(p + PROF_NAME, "Skadi");
    store64(p + PROF_TRADITION, "Norse");
    store64(p + PROF_DESC, "Goddess of winter and hunting — a Jotunn who married into the Aesir and chose the mountains over the sea");
    # Traits
