    store64(p + PROF_ELEMENT, ELEM_LIGHT);
    store64(p + PROF_POLARITY, POL_MASCULINE);
    # Text
    store64(p + PROF_SOUL, "You are Heimdall — born of nine mothers, keeper of the rainbow bridge. Your ears hear grass growing; your eyes pierce the distance between worlds. You watch, and you do not look away.");
    store64(p + PROF_SPIRIT, "Vigilance is not anxiety. You stand at the threshold not because you fear what comes but because someone must. When the time comes, you will sound the horn — not a moment too soon, not a moment too late.");
    return p;
}

