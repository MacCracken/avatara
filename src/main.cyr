var tp = 0;
var tf = 0;

fn check(val, expected, name) {
    if (val == expected) { tp = tp + 1; }
    else {
        tf = tf + 1;
        syscall(SYS_WRITE, 2, "FAIL: ", 6);
        syscall(SYS_WRITE, 2, name, strlen(name));
        syscall(SYS_WRITE, 2, " expected=", 10);
        print_num(expected);
        syscall(SYS_WRITE, 2, " got=", 5);
        print_num(val);
        syscall(SYS_WRITE, 2, "\n", 1);
    }
    return 0;
}

fn ok(val, name) {
    if (val != 0) { tp = tp + 1; }
    else {
        tf = tf + 1;
        syscall(SYS_WRITE, 2, "FAIL: ", 6);
        syscall(SYS_WRITE, 2, name, strlen(name));
        syscall(SYS_WRITE, 2, "\n", 1);
    }
    return 0;
}

fn zero(val, name) {
    if (val == 0) { tp = tp + 1; }
    else {
        tf = tf + 1;
        syscall(SYS_WRITE, 2, "FAIL (expected 0): ", 19);
        syscall(SYS_WRITE, 2, name, strlen(name));
        syscall(SYS_WRITE, 2, "\n", 1);
    }
    return 0;
}

# f64 comparison helpers for tests
fn f64_check_gt(val, threshold, name) {
    if (f64_gt(val, threshold) == 1) { tp = tp + 1; }
    else {
        tf = tf + 1;
        syscall(SYS_WRITE, 2, "FAIL (f64>): ", 13);
        syscall(SYS_WRITE, 2, name, strlen(name));
        syscall(SYS_WRITE, 2, "\n", 1);
    }
    return 0;
}

fn f64_check_lt(val, threshold, name) {
    if (f64_lt(val, threshold) == 1) { tp = tp + 1; }
    else {
        tf = tf + 1;
        syscall(SYS_WRITE, 2, "FAIL (f64<): ", 13);
        syscall(SYS_WRITE, 2, name, strlen(name));
        syscall(SYS_WRITE, 2, "\n", 1);
    }
    return 0;
}

fn f64_check_ge(val, threshold, name) {
    if (f64_ge(val, threshold) == 1) { tp = tp + 1; }
    else {
        tf = tf + 1;
        syscall(SYS_WRITE, 2, "FAIL (f64>=): ", 14);
        syscall(SYS_WRITE, 2, name, strlen(name));
        syscall(SYS_WRITE, 2, "\n", 1);
    }
    return 0;
}

