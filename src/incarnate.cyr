    store64(p + PROF_SPIRIT, "Your nature is uncompromising directness. You did not soften the teaching to make it palatable. When the Emperor asked about merit, you said 'no merit.' When asked about the holy, you said 'vast emptiness, nothing holy.' This is the sword that frees.");
    return p;
}

