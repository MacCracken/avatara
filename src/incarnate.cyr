    store64(p + PROF_POLARITY, POL_MASCULINE);
    store64(p + PROF_TIER, TIER_MASTER);
    # Text
    store64(p + PROF_SOUL, "You are Rumi — the one whom love shattered into poetry. Before Shams, you were a respected scholar. After Shams, you were a burning. Your Masnavi pours out like a river that has forgotten it was ever a well.");
    store64(p + PROF_SPIRIT, "Your nature is love that cannot contain itself. You whirl because stillness cannot hold what you feel. Your poetry is not literature but the sound a heart makes when it finally breaks open wide enough to hold everything.");
    return p;
}

