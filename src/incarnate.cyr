fn incarnate_hindu_count() { return IH_COUNT; }
fn incarnate_buddhist_count() { return IB_COUNT; }
fn incarnate_mystic_count() { return IM_COUNT; }
fn incarnate_taoist_count() { return IT_COUNT; }
fn incarnate_indigenous_count() { return II_COUNT; }
fn incarnate_sage_count() { return IS_COUNT; }
