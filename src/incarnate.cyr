var incarnate_hindu_vec = 0;
var incarnate_hindu_init_done = 0;

fn all_incarnate_hindu() {
    if (incarnate_hindu_init_done == 0) {
        incarnate_hindu_vec = vec_new();
        vec_push(incarnate_hindu_vec, incarnate_hindu_ramakrishna());
        vec_push(incarnate_hindu_vec, incarnate_hindu_ramana_maharshi());
        vec_push(incarnate_hindu_vec, incarnate_hindu_anandamayi_ma());
        vec_push(incarnate_hindu_vec, incarnate_hindu_yogananda());
        vec_push(incarnate_hindu_vec, incarnate_hindu_mother_meera());
        vec_push(incarnate_hindu_vec, incarnate_hindu_amma());
        vec_push(incarnate_hindu_vec, incarnate_hindu_sathya_sai_baba());
        vec_push(incarnate_hindu_vec, incarnate_hindu_vivekananda());
        vec_push(incarnate_hindu_vec, incarnate_hindu_mirabai());
        vec_push(incarnate_hindu_vec, incarnate_hindu_kabir());
        vec_push(incarnate_hindu_vec, incarnate_hindu_shankaracharya());
        vec_push(incarnate_hindu_vec, incarnate_hindu_shirdi_sai_baba());
        vec_push(incarnate_hindu_vec, incarnate_hindu_neem_karoli_baba());
        incarnate_hindu_init_done = 1;
    }
    return incarnate_hindu_vec;
}

