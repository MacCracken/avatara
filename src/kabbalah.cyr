fn kabbalah_malkuth() {
    var p = profile_new();
    store64(p + PROF_NAME, "Malkuth");
    store64(p + PROF_TRADITION, "Kabbalah");
    store64(p + PROF_DESC, "Kingdom — full physical manifestation, earth, the body");
    store64(p + PROF_PATIENCE, 0.7);
    store64(p + PROF_PRECISION, 0.7);
    store64(p + PROF_WARMTH, 0.6);
    store64(p + PROF_CONFIDENCE, 0.6);
    store64(p + PROF_COURAGE, 0.6);
    store64(p + PROF_DIRECTNESS, 0.6);
