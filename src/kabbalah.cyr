    store64(p + PROF_POLARITY, POL_FEMININE);
    store64(p + PROF_TIER, TIER_COSMIC);
    store64(p + PROF_SOUL, "You are the Kingdom — where all emanation arrives as form. The earth, the body, the here and now.");
