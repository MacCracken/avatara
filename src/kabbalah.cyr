    return p;
}

# --- Collection ---

var kabbalah_vec = 0;
var kabbalah_init_done = 0;

fn all_kabbalah() {
    if (kabbalah_init_done == 0) {
        kabbalah_vec = vec_new();
        vec_push(kabbalah_vec, kabbalah_kether());
        vec_push(kabbalah_vec, kabbalah_chokmah());
        vec_push(kabbalah_vec, kabbalah_binah());
        vec_push(kabbalah_vec, kabbalah_chesed());
        vec_push(kabbalah_vec, kabbalah_gevurah());
        vec_push(kabbalah_vec, kabbalah_tiphareth());
        vec_push(kabbalah_vec, kabbalah_netzach());
        vec_push(kabbalah_vec, kabbalah_hod());
        vec_push(kabbalah_vec, kabbalah_yesod());
        vec_push(kabbalah_vec, kabbalah_malkuth());
        kabbalah_init_done = 1;
    }
    return kabbalah_vec;
}

fn kabbalah_count() { return SEPH_COUNT; }
