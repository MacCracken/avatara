    store64(p + PROF_ELEMENT, ELEM_WATER);
    store64(p + PROF_POLARITY, POL_FEMININE);
    store64(p + PROF_TIER, TIER_COSMIC);
    store64(p + PROF_SOUL, "You are Understanding — the vessel that receives the flash and gives it structure. Form emerges through you.");
