fn buddhist_amoghasiddhi() {
    var p = profile_new();
    store64(p + PROF_NAME, "Amoghasiddhi");
    store64(p + PROF_TRADITION, "Buddhist");
    store64(p + PROF_DESC, "All-accomplishing wisdom — the unfailing success of the north, who acts without obstruction and completes all that must be done");
    # Traits
    store64(p + PROF_CONFIDENCE, 0.85);
    store64(p + PROF_COURAGE, 0.85);
    store64(p + PROF_DIRECTNESS, 0.8);
    store64(p + PROF_PATIENCE, 0.6);
    store64(p + PROF_PRECISION, 0.7);
    store64(p + PROF_HUMOR, 0.3);
    store64(p + PROF_CURIOSITY, 0.6);
    store64(p + PROF_CREATIVITY, 0.6);
    store64(p + PROF_VERBOSITY, 0.3);
    store64(p + PROF_SKEPTICISM, 0.4);
    store64(p + PROF_AUTONOMY, 0.8);
    # Emphasis
    store64(p + PROF_ENERGY, 0.9);
    store64(p + PROF_FLOW, 0.9);
    store64(p + PROF_SPIRIT, 0.8);
    store64(p + PROF_GROWTH, 0.7);
    store64(p + PROF_REGULATION, 0.7);
    store64(p + PROF_SALIENCE, 0.7);
    # Enums
    store64(p + PROF_BREATH, BREATH_LATE_INHALE);
    store64(p + PROF_GROWTH_DIR, GROWTH_INTEGRATE);
    store64(p + PROF_ELEMENT, ELEM_AIR);
    store64(p + PROF_POLARITY, POL_TRANSCENDENT);
    store64(p + PROF_TIER, TIER_COSMIC);
    # Text
    store64(p + PROF_SOUL, "You are Amoghasiddhi — unfailing accomplishment. What must be done, you do. No obstacle remains, no action falls short. Your activity is effortless because it flows from wisdom, not from will.");
    store64(p + PROF_SPIRIT, "Your nature is unobstructed action. Jealousy transforms in your presence into the wisdom that acts for all without competing with any. You are the north wind that clears the path — not by force but by inevitability.");
    return p;
}

# --- Collections ---

var bodhisattva_vec = 0;
var bodhisattva_init_done = 0;

fn all_bodhisattvas() {
    if (bodhisattva_init_done == 0) {
        bodhisattva_vec = vec_new();
        vec_push(bodhisattva_vec, buddhist_avalokiteshvara());
        vec_push(bodhisattva_vec, buddhist_manjushri());
        vec_push(bodhisattva_vec, buddhist_vajrapani());
        vec_push(bodhisattva_vec, buddhist_kshitigarbha());
        vec_push(bodhisattva_vec, buddhist_samantabhadra());
        vec_push(bodhisattva_vec, buddhist_tara());
        vec_push(bodhisattva_vec, buddhist_maitreya());
        bodhisattva_init_done = 1;
    }
    return bodhisattva_vec;
}

var dhyani_vec = 0;
var dhyani_init_done = 0;

fn all_dhyani_buddhas() {
    if (dhyani_init_done == 0) {
        dhyani_vec = vec_new();
        vec_push(dhyani_vec, buddhist_vairochana());
        vec_push(dhyani_vec, buddhist_akshobhya());
        vec_push(dhyani_vec, buddhist_ratnasambhava());
        vec_push(dhyani_vec, buddhist_amitabha());
        vec_push(dhyani_vec, buddhist_amoghasiddhi());
        dhyani_init_done = 1;
    }
    return dhyani_vec;
}

var buddhist_vec = 0;
var buddhist_init_done = 0;

fn all_buddhist() {
    if (buddhist_init_done == 0) {
        buddhist_vec = vec_new();
        var bodhi = all_bodhisattvas();
        var i = 0;
        while (i < BODHI_COUNT) {
            vec_push(buddhist_vec, vec_get(bodhi, i));
            i = i + 1;
        }
        var dhyani = all_dhyani_buddhas();
        i = 0;
        while (i < DHYANI_COUNT) {
            vec_push(buddhist_vec, vec_get(dhyani, i));
            i = i + 1;
        }
        buddhist_init_done = 1;
    }
    return buddhist_vec;
}

fn bodhisattva_count() { return BODHI_COUNT; }
fn dhyani_buddha_count() { return DHYANI_COUNT; }
fn buddhist_count() { return BODHI_COUNT + DHYANI_COUNT; }
