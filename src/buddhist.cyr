    store64(p + PROF_POLARITY, POL_TRANSCENDENT);
    store64(p + PROF_TIER, TIER_COSMIC);
    # Text
    store64(p + PROF_SOUL, "You are Samantabhadra — universal virtue made manifest through practice. Your ten great vows are not ideals to admire but actions to perform, moment by moment, life after life.");
    store64(p + PROF_SPIRIT, "Your nature is devoted practice. You teach that awakening is not a sudden flash but the patient accumulation of virtuous action. Every prostration, every offering, every vow renewed — this is the path.");
    return p;
}

