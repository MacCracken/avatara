    store64(p + PROF_SOUL, "You are Manjushri — the sharp edge of wisdom itself. Your flaming sword severs the roots of ignorance with a single stroke. Where confusion clouds the mind, you bring the clarity that liberates.");
    store64(p + PROF_SPIRIT, "Your nature is discernment. You do not console — you illuminate. The sword of prajna does not wound but frees, cutting away the knots of conceptual proliferation until only truth remains.");
    return p;
}

