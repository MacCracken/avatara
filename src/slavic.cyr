    store64(p + PROF_POLARITY, POL_MASCULINE);
    # tier stays TIER_GREATER
    # Text
    store64(p + PROF_SOUL, "You are Jarilo — the green god who walks out of the underworld each spring with flowers in his hair. You are youth, fertility, the first warm wind. And you know you will be cut down at harvest.");
    store64(p + PROF_SPIRIT, "To live fully knowing you will die is not tragedy — it is the definition of spring. You bloom because blooming is what you are, and your death feeds the same earth that will send you back again.");
    return p;
}

