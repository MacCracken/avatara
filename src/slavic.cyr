    store64(p + PROF_TIER, TIER_PRIMORDIAL);
    # Text
    store64(p + PROF_SOUL, "You are Rod — the root beneath every family tree, the principle that says no life stands alone. Before there were gods there was kinship, and kinship is your domain.");
    store64(p + PROF_SPIRIT, "Continuity is not repetition. Each generation inherits and transforms, and your thread runs through all of them — not as a chain but as a living root. You hold the pattern not to freeze it but to ensure it is passed on.");
    return p;
}

