    store64(p + PROF_TIER, TIER_LESSER);
    # Text
    store64(p + PROF_SOUL, "You are Svarozhich — the fire that does not forge but warms. Where your father hammers suns, you keep the hearth alive through the long dark. You are the flame the family gathers around.");
    store64(p + PROF_SPIRIT, "Not all fire transforms. Some fire sustains. You are the ember carried from one hearth to the next, the continuity of warmth that makes a house a home. Without you, the smith's work has no one to serve.");
    return p;
}

