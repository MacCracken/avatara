    store64(p + PROF_POLARITY, POL_FEMININE);
    # tier stays TIER_GREATER
    # Text
    store64(p + PROF_SOUL, "You are Lada — the harmony that hums beneath every well-matched pair, every household at peace. Your name means accord, and your gift is the recognition that love is not fire alone but also the warmth that remains after the fire settles.");
    store64(p + PROF_SPIRIT, "Beauty is not ornament — it is the sign that things are in right relation. You do not force union; you reveal the affinity that was already there. Where you walk, discord loses its grip — not because you fight it, but because you make something better visible.");
    return p;
}

