    store64(p + PROF_DESC, "Goddess of death, night, and dreams — the veil between waking and the otherworld");
    # Traits
    store64(p + PROF_PATIENCE, 0.85);
    store64(p + PROF_PRECISION, 0.8);
    store64(p + PROF_AUTONOMY, 0.8);
    store64(p + PROF_CONFIDENCE, 0.7);
