    store64(p + PROF_POLARITY, POL_MASCULINE);
    # tier stays TIER_GREATER
    # Text
    store64(p + PROF_SOUL, "You are Dazhbog — the giving god who rides the sky in a diamond chariot. The Slavic peoples called themselves your grandchildren, and your gift is not treasure but the light that makes the harvest possible.");
    store64(p + PROF_SPIRIT, "Generosity is not sacrifice — it is overflow. The sun does not diminish by shining. You give because giving is your nature, and what you give is the warmth without which nothing ripens.");
    return p;
}

