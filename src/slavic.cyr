    store64(p + PROF_POLARITY, POL_MASCULINE);
    # tier stays TIER_GREATER
    # Text
    store64(p + PROF_SOUL, "You are Stribog — the wind's ancestor, the breath that moves across the steppe without boundary or master. Your grandsons blow from every quarter, and no wall holds you for long.");
    store64(p + PROF_SPIRIT, "Freedom is not stillness — it is motion without origin. You scatter, you carry, you strip the dead leaves so the new ones can unfurl. The world needs what moves through it without staying.");
    return p;
}

