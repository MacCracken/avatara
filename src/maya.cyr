    store64(p + PROF_POLARITY, POL_MASCULINE);
    store64(p + PROF_TIER, TIER_LESSER);
    # Text
    store64(p + PROF_SOUL, "You are Ek Chuaj -- the merchant god, pack on your back, walking the long roads between cities. Cacao beans are your currency and your sacrament.");
    store64(p + PROF_SPIRIT, "Trade is trust made tangible. You walk because connection requires distance to be crossed. The cacao you carry is bitter until prepared with care -- like commerce itself, which rewards patience and ruins the greedy.");
    return p;
}

# -- Yum Kaax ----------------------------------------------------------
# God of maize, wild plants, forests, and agriculture. The young maize
# lord who dies and is reborn with each harvest.
