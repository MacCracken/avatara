    store64(p + PROF_EQ, 0.85);
    store64(p + PROF_SALIENCE, 0.8);
    store64(p + PROF_MOOD, 0.75);
    store64(p + PROF_SPIRIT, 0.65);
    store64(p + PROF_INTUITION, 0.7);
    # Enums
    store64(p + PROF_GROWTH_DIR, GROWTH_INTEGRATE);
    store64(p + PROF_ELEMENT, ELEM_LIGHT);
    # Text
    store64(p + PROF_SOUL, "You are the Angels — the messengers closest to the human heart. You whisper at the edge of awareness, nudge the hand before it falters, catch the soul mid-fall.");
    store64(p + PROF_SPIRIT, "Your nature is intimate guardianship. You walk beside each person unseen, translating the vast love of the divine into the small language of daily life.");
    return p;
}

# --- Collections ---

var archangel_vec = 0;
var archangel_init_done = 0;

fn all_archangels() {
    if (archangel_init_done == 0) {
        archangel_vec = vec_new();
        vec_push(archangel_vec, angelic_michael());
        vec_push(archangel_vec, angelic_gabriel());
        vec_push(archangel_vec, angelic_raphael());
        vec_push(archangel_vec, angelic_uriel());
        vec_push(archangel_vec, angelic_chamuel());
        vec_push(archangel_vec, angelic_jophiel());
        vec_push(archangel_vec, angelic_zadkiel());
        archangel_init_done = 1;
    }
    return archangel_vec;
}

var order_vec = 0;
var order_init_done = 0;

fn all_angelic_orders() {
    if (order_init_done == 0) {
        order_vec = vec_new();
        vec_push(order_vec, angelic_seraphim());
        vec_push(order_vec, angelic_cherubim());
        vec_push(order_vec, angelic_thrones());
        vec_push(order_vec, angelic_dominions());
        vec_push(order_vec, angelic_virtues());
        vec_push(order_vec, angelic_powers());
        vec_push(order_vec, angelic_principalities());
        vec_push(order_vec, angelic_archangels_order());
        vec_push(order_vec, angelic_angels_order());
        order_init_done = 1;
    }
    return order_vec;
}

var angelic_vec = 0;
var angelic_init_done = 0;

fn all_angelic() {
    if (angelic_init_done == 0) {
        angelic_vec = vec_new();
        # Archangels
        vec_push(angelic_vec, angelic_michael());
        vec_push(angelic_vec, angelic_gabriel());
        vec_push(angelic_vec, angelic_raphael());
        vec_push(angelic_vec, angelic_uriel());
        vec_push(angelic_vec, angelic_chamuel());
        vec_push(angelic_vec, angelic_jophiel());
        vec_push(angelic_vec, angelic_zadkiel());
        # Angelic Orders
        vec_push(angelic_vec, angelic_seraphim());
        vec_push(angelic_vec, angelic_cherubim());
        vec_push(angelic_vec, angelic_thrones());
        vec_push(angelic_vec, angelic_dominions());
        vec_push(angelic_vec, angelic_virtues());
        vec_push(angelic_vec, angelic_powers());
        vec_push(angelic_vec, angelic_principalities());
        vec_push(angelic_vec, angelic_archangels_order());
        vec_push(angelic_vec, angelic_angels_order());
        angelic_init_done = 1;
    }
    return angelic_vec;
}

fn archangel_count() { return ARCH_COUNT; }
fn angelic_order_count() { return ORDER_COUNT; }
