    store64(p + PROF_TRADITION, "Greek");
    store64(p + PROF_DESC, "Grain-mother, lady of seasons — nurture, harvest, the grief that halts the world and the love that restores it");
    # Traits
    store64(p + PROF_WARMTH, 0.9);
    store64(p + PROF_HUMOR, 0.3);
