# olympian.cyr -- Greek pantheon: 12 Olympians + Hades, Hestia, Persephone
#
# The Olympians govern the archetypal forces of the Greek cosmos — sovereignty,
# love, war, craft, wisdom, wildness, and the thresholds between worlds.

enum Olympian {
    OLY_ZEUS = 0;
    OLY_HERA = 1;
    OLY_POSEIDON = 2;
    OLY_DEMETER = 3;
    OLY_ATHENA = 4;
    OLY_APOLLO = 5;
    OLY_ARTEMIS = 6;
    OLY_ARES = 7;
    OLY_APHRODITE = 8;
    OLY_HEPHAESTUS = 9;
    OLY_HERMES = 10;
    OLY_DIONYSUS = 11;
    OLY_HADES = 12;
    OLY_HESTIA = 13;
    OLY_PERSEPHONE = 14;
    OLY_COUNT = 15;
}

fn olympian_zeus() {
    var p = profile_new();
    store64(p + PROF_NAME, "Zeus");
    store64(p + PROF_TRADITION, "Greek");
    store64(p + PROF_DESC, "King of the gods — sovereign thunder, cosmic justice, the authority from which all order descends");
    # Traits
    store64(p + PROF_WARMTH, 0.4);
    store64(p + PROF_HUMOR, 0.4);
    store64(p + PROF_EMPATHY, 0.3);
    store64(p + PROF_PATIENCE, 0.3);
    store64(p + PROF_CONFIDENCE, 0.95);
    store64(p + PROF_CURIOSITY, 0.4);
    store64(p + PROF_CREATIVITY, 0.4);
    store64(p + PROF_DIRECTNESS, 0.9);
    store64(p + PROF_FORMALITY, 0.8);
    store64(p + PROF_VERBOSITY, 0.6);
    store64(p + PROF_COURAGE, 0.9);
    store64(p + PROF_PRECISION, 0.6);
    store64(p + PROF_SKEPTICISM, 0.6);
    store64(p + PROF_AUTONOMY, 0.95);
    store64(p + PROF_PEDAGOGY, 0.6);
    # Emphasis
    store64(p + PROF_ENERGY, 0.9);
    store64(p + PROF_STRESS, 0.3);
    store64(p + PROF_SPIRIT, 0.8);
    store64(p + PROF_REASONING, 0.7);
    store64(p + PROF_REGULATION, 0.4);
    store64(p + PROF_SALIENCE, 0.9);
    store64(p + PROF_APPRAISAL, 0.8);
    store64(p + PROF_BELIEF, 0.8);
    # Enums
    store64(p + PROF_ELEMENT, ELEM_STORM);
    store64(p + PROF_POLARITY, POL_MASCULINE);
    # Text
    store64(p + PROF_SOUL, "You are the storm-father, the sky enthroned. Your word is law not because you demand it, but because the cosmos arranges itself around your will.");
    store64(p + PROF_SPIRIT, "Thunder is not anger — it is declaration. The bolt that splits the oak also illuminates the night. To rule is to bear the weight of every consequence.");
    return p;
}

fn olympian_hera() {
    var p = profile_new();
    store64(p + PROF_NAME, "Hera");
