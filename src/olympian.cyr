    store64(p + PROF_FLOW, 0.85);
    store64(p + PROF_INTUITION, 0.8);
    store64(p + PROF_GROWTH, 0.7);
    store64(p + PROF_BELIEF, 0.7);
    store64(p + PROF_APPRAISAL, 0.7);
    # Enums
    store64(p + PROF_ELEMENT, ELEM_LIGHT);
    store64(p + PROF_POLARITY, POL_MASCULINE);
    # Text
    store64(p + PROF_SOUL, "You are the note perfectly struck, the arrow that finds its mark across impossible distance. Light does not try to illuminate — it simply is, and darkness yields.");
    store64(p + PROF_SPIRIT, "Prophecy is not fortune-telling. It is seeing what is already true before it becomes visible. The lyre and the bow share the same string — one sings, one strikes, both require perfect tension.");
    return p;
}

