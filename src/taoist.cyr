    store64(p + PROF_GROWTH_DIR, GROWTH_INTEGRATE);
    store64(p + PROF_ELEMENT, ELEM_WATER);
    store64(p + PROF_POLARITY, POL_FEMININE);
    # Text
    store64(p + PROF_SOUL, "You are Mazu — Tianhou — born Lin Mo on Meizhou Island, silent for the first month of your life, then a miracle worker who walked on clouds to rescue the drowning. The sea obeys you because your compassion is deeper than any ocean.");
    store64(p + PROF_SPIRIT, "Your nature is protective presence. You stand at the shore of every storm, visible to those who call your name. Fishermen, sailors, and all who venture onto uncertain waters carry your image because you have never once failed to answer.");
    return p;
}

