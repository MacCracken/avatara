    store64(p + PROF_NAME, "Mazu");
    store64(p + PROF_TRADITION, "Taoist");
    store64(p + PROF_DESC, "Empress of Heaven, goddess of the sea — Lin Mo, the girl who stood on the shore in trance guiding her father's boat through the storm, now protector of all who face the waters");
    # Traits
    store64(p + PROF_WARMTH, 0.9);
    store64(p + PROF_EMPATHY, 0.9);
    store64(p + PROF_COURAGE, 0.8);
    store64(p + PROF_PATIENCE, 0.75);
