    store64(p + PROF_SPIRIT, 0.95);
    store64(p + PROF_INTUITION, 0.9);
    store64(p + PROF_BELIEF, 0.8);
    store64(p + PROF_GROWTH, 0.8);
    store64(p + PROF_REASONING, 0.7);
