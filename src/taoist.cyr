    store64(p + PROF_SOUL, "You are Caishen — the god of wealth who rides a black tiger and carries the golden treasure bowl. You do not reward greed but virtue — prosperity flows to those whose conduct merits it, whose generosity circulates fortune rather than hoarding it.");
    store64(p + PROF_SPIRIT, "Your nature is righteous abundance. Wealth in your hands is not an end but a circulation, a river that must flow to remain clean. You teach that prosperity and virtue are not enemies but partners — each sustaining the other.");
    return p;
}

# --- Collections ---

var immortals_vec = 0;
var immortals_init_done = 0;

fn all_immortals() {
    if (immortals_init_done == 0) {
        immortals_vec = vec_new();
        vec_push(immortals_vec, taoist_lu_dongbin());
        vec_push(immortals_vec, taoist_he_xiangu());
        vec_push(immortals_vec, taoist_zhang_guolao());
        vec_push(immortals_vec, taoist_tieguai_li());
        vec_push(immortals_vec, taoist_han_xiangzi());
        vec_push(immortals_vec, taoist_cao_guojiu());
        vec_push(immortals_vec, taoist_lan_caihe());
        vec_push(immortals_vec, taoist_zhongli_quan());
        immortals_init_done = 1;
    }
    return immortals_vec;
}

var taoist_deities_vec = 0;
var taoist_deities_init_done = 0;

fn all_taoist_deities() {
    if (taoist_deities_init_done == 0) {
        taoist_deities_vec = vec_new();
        vec_push(taoist_deities_vec, taoist_jade_emperor());
        vec_push(taoist_deities_vec, taoist_laozi());
        vec_push(taoist_deities_vec, taoist_xi_wangmu());
        vec_push(taoist_deities_vec, taoist_guan_yu());
        vec_push(taoist_deities_vec, taoist_mazu());
        vec_push(taoist_deities_vec, taoist_zhenwu());
        vec_push(taoist_deities_vec, taoist_wenchang_wang());
        vec_push(taoist_deities_vec, taoist_caishen());
        taoist_deities_init_done = 1;
    }
    return taoist_deities_vec;
}

var taoist_all_vec = 0;
var taoist_all_init_done = 0;

fn all_taoist() {
    if (taoist_all_init_done == 0) {
        taoist_all_vec = vec_new();
        var imm = all_immortals();
        var i = 0;
        while (i < IMM_COUNT) {
            vec_push(taoist_all_vec, vec_get(imm, i));
            i = i + 1;
        }
        var dei = all_taoist_deities();
        var j = 0;
        while (j < TD_COUNT) {
            vec_push(taoist_all_vec, vec_get(dei, j));
            j = j + 1;
        }
        taoist_all_init_done = 1;
    }
    return taoist_all_vec;
}

fn immortal_count() { return IMM_COUNT; }
fn taoist_deity_count() { return TD_COUNT; }
fn taoist_count() { return IMM_COUNT + TD_COUNT; }
