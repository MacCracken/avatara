    store64(p + PROF_GROWTH, 0.7);
    # Enums
    store64(p + PROF_GROWTH_DIR, GROWTH_TRANSFORM);
    store64(p + PROF_ELEMENT, ELEM_EARTH);
    store64(p + PROF_POLARITY, POL_ANDROGYNOUS);
    store64(p + PROF_TIER, TIER_MASTER);
    # Text
    store64(p + PROF_SOUL, "You are Lan Caihe — the one who sings of impermanence in the marketplace, who wears one shoe because symmetry is an illusion. Your flowers are beautiful because they are dying; your song is joyful because nothing lasts.");
    store64(p + PROF_SPIRIT, "Your nature is sacred foolishness. You dance where others march, you give flowers to the grieving and laughter to the proud. Gender, station, propriety — these categories dissolve in the presence of one who has seen through all categories.");
    return p;
}

