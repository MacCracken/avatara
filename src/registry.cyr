# Filter profiles by cosmic tier.
fn query_tier(tier) {
    var result = vec_new();
    var v = all_profiles();
    var n = vec_len(v);
    for (var i = 0; i < n; i = i + 1) {
        var p = vec_get(v, i);
        if (prof_tier(p) == tier) { vec_push(result, p); }
    }
    return result;
}

# Filter a vec by tradition (for chaining).
fn filter_tradition(src, tradition) {
    var result = vec_new();
    var n = vec_len(src);
    for (var i = 0; i < n; i = i + 1) {
        var p = vec_get(src, i);
        if (streq(prof_tradition(p), tradition) == 1) {
            vec_push(result, p);
        }
    }
    return result;
}

# Filter a vec by minimum trait (for chaining).
fn filter_min_trait(src, offset, min_val) {
    var result = vec_new();
    var n = vec_len(src);
    for (var i = 0; i < n; i = i + 1) {
        var p = vec_get(src, i);
        if (f64_ge(load64(p + offset), min_val) == 1) {
            vec_push(result, p);
        }
    }
    return result;
}
