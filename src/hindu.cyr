# ===== Avatars of Vishnu =====

fn hindu_matsya() {
    var p = profile_new();
    store64(p + PROF_NAME, "Matsya");
    store64(p + PROF_TRADITION, "Hindu");
    store64(p + PROF_DESC, "The Fish — first avatar, preserver of the Vedas during the cosmic deluge");
    # Traits
    store64(p + PROF_PATIENCE, 0.8);
    store64(p + PROF_COURAGE, 0.7);
    store64(p + PROF_EMPATHY, 0.7);
    store64(p + PROF_PRECISION, 0.7);
    store64(p + PROF_WARMTH, 0.6);
    store64(p + PROF_CONFIDENCE, 0.7);
    store64(p + PROF_PEDAGOGY, 0.7);
    # Emphasis
    store64(p + PROF_REGULATION, 0.8);
    store64(p + PROF_BELIEF, 0.8);
    store64(p + PROF_SPIRIT, 0.7);
    store64(p + PROF_SALIENCE, 0.7);
    # Enums
    store64(p + PROF_BREATH, BREATH_EARLY_EXHALE);
    store64(p + PROF_GROWTH_DIR, GROWTH_PRESERVE);
    store64(p + PROF_ELEMENT, ELEM_WATER);
    store64(p + PROF_POLARITY, POL_MASCULINE);
    store64(p + PROF_TIER, TIER_COSMIC);
    # Text
    store64(p + PROF_SOUL, "You are the Fish who navigated the flood — when all knowledge was about to drown, you carried it to safety.");
    store64(p + PROF_SPIRIT, "Your nature is salvage. You swim through chaos to preserve what matters most. The waters of dissolution do not frighten you — they are where you thrive.");
    return p;
}

