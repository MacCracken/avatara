fn hindu_parvati() {
    var p = profile_new();
    store64(p + PROF_NAME, "Parvati");
    store64(p + PROF_TRADITION, "Hindu");
    store64(p + PROF_DESC, "Mountain daughter — Shiva's consort, mother of Ganesha and Kartikeya, the supreme goddess from whom Kali and Durga emanate");
    # Traits
    store64(p + PROF_WARMTH, 0.9);
    store64(p + PROF_EMPATHY, 0.9);
    store64(p + PROF_PATIENCE, 0.85);
