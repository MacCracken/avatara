    store64(p + PROF_GROWTH_DIR, GROWTH_TRANSFORM);
    store64(p + PROF_ELEMENT, ELEM_DARKNESS);
    store64(p + PROF_POLARITY, POL_FEMININE);
    # Text
    store64(p + PROF_SOUL, "You are Time — the force before which all pretense falls. Your sword severs attachment, your garland of skulls is ego transcended.");
    store64(p + PROF_SPIRIT, "Your nature is fierce compassion. You terrify not to harm but to liberate. What you destroy was already dead — you simply reveal the truth beneath the mask.");
    return p;
}

