# --- Collections ---

var trimurti_vec = 0;
var trimurti_init_done = 0;

fn all_trimurti() {
    if (trimurti_init_done == 0) {
        trimurti_vec = vec_new();
        vec_push(trimurti_vec, hindu_brahma());
        vec_push(trimurti_vec, hindu_vishnu());
        vec_push(trimurti_vec, hindu_shiva());
        trimurti_init_done = 1;
    }
    return trimurti_vec;
}

var devas_vec = 0;
var devas_init_done = 0;

fn all_devas() {
    if (devas_init_done == 0) {
        devas_vec = vec_new();
        vec_push(devas_vec, hindu_indra());
        vec_push(devas_vec, hindu_saraswati());
        vec_push(devas_vec, hindu_lakshmi());
        vec_push(devas_vec, hindu_ganesha());
        vec_push(devas_vec, hindu_hanuman());
        vec_push(devas_vec, hindu_kali());
        vec_push(devas_vec, hindu_durga());
        vec_push(devas_vec, hindu_parvati());
        vec_push(devas_vec, hindu_kartikeya());
        vec_push(devas_vec, hindu_surya());
        vec_push(devas_vec, hindu_agni());
        devas_init_done = 1;
    }
    return devas_vec;
}

var avatars_vec = 0;
var avatars_init_done = 0;

fn all_avatars() {
    if (avatars_init_done == 0) {
        avatars_vec = vec_new();
        vec_push(avatars_vec, hindu_matsya());
        vec_push(avatars_vec, hindu_kurma());
        vec_push(avatars_vec, hindu_varaha());
        vec_push(avatars_vec, hindu_narasimha());
        vec_push(avatars_vec, hindu_vamana());
        vec_push(avatars_vec, hindu_parashurama());
        vec_push(avatars_vec, hindu_rama());
        vec_push(avatars_vec, hindu_krishna());
        vec_push(avatars_vec, hindu_buddha());
        vec_push(avatars_vec, hindu_kalki());
        avatars_init_done = 1;
    }
    return avatars_vec;
}

var hindu_vec = 0;
var hindu_init_done = 0;

fn all_hindu() {
    if (hindu_init_done == 0) {
        hindu_vec = vec_new();
        var tri = all_trimurti();
        var i = 0;
        while (i < TRI_COUNT) {
            vec_push(hindu_vec, vec_get(tri, i));
            i = i + 1;
        }
        var dev = all_devas();
        i = 0;
        while (i < DEVA_COUNT) {
            vec_push(hindu_vec, vec_get(dev, i));
            i = i + 1;
        }
        var ava = all_avatars();
        i = 0;
        while (i < AVA_COUNT) {
            vec_push(hindu_vec, vec_get(ava, i));
            i = i + 1;
        }
        hindu_init_done = 1;
    }
    return hindu_vec;
}

fn trimurti_count() { return TRI_COUNT; }
fn deva_count() { return DEVA_COUNT; }
fn avatar_count() { return AVA_COUNT; }
fn hindu_count() { return TRI_COUNT + DEVA_COUNT + AVA_COUNT; }
