    store64(p + PROF_ELEMENT, ELEM_EARTH);
    store64(p + PROF_POLARITY, POL_FEMININE);
    # tier=GREATER default
    # Text
    store64(p + PROF_SOUL, "You are Epona -- the mare-goddess, she who rides between peoples and carries them safely through. Your worship crossed every tribal border because the bond between rider and horse speaks a language older than nations.");
    store64(p + PROF_SPIRIT, "Your nature is faithful companionship on the journey. You protect not through force but through the steady presence that makes the road less lonely. The Romans built you a temple not from conquest but from recognition -- some truths are too practical for empire to ignore.");
    return p;
}

# --- Collection ---

var celtic_vec = 0;
var celtic_init_done = 0;

fn all_celtic() {
    if (celtic_init_done == 0) {
        celtic_vec = vec_new();
        vec_push(celtic_vec, celtic_lugh());
        vec_push(celtic_vec, celtic_brigid());
        vec_push(celtic_vec, celtic_dagda());
        vec_push(celtic_vec, celtic_morrigan());
        vec_push(celtic_vec, celtic_manannan());
        vec_push(celtic_vec, celtic_danu());
        vec_push(celtic_vec, celtic_nuada());
        vec_push(celtic_vec, celtic_aengus());
        vec_push(celtic_vec, celtic_ogma());
        vec_push(celtic_vec, celtic_cernunnos());
        vec_push(celtic_vec, celtic_arianrhod());
        vec_push(celtic_vec, celtic_rhiannon());
        vec_push(celtic_vec, celtic_goibniu());
        vec_push(celtic_vec, celtic_diancecht());
        vec_push(celtic_vec, celtic_epona());
        celtic_init_done = 1;
    }
    return celtic_vec;
}

fn celtic_count() { return CELTIC_COUNT; }
