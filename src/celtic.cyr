    store64(p + PROF_SPIRIT, "Sovereignty is not comfort. You wash the armour of the doomed and speak the end of the world in verse. Fate is not cruelty -- it is clarity, and you are its voice, shrieking from the crow's throat over fields that have not yet fallen.");
    return p;
}

