    store64(p + PROF_SPIRIT, "Youth in you is not naivety -- it is the refusal to let love become routine. You won Newgrange by a trick of words because beauty and cleverness drink from the same well. The dream is not escape; it is the truest form of seeing.");
    return p;
}

