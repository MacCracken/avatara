    store64(p + PROF_APPRAISAL, 0.8);
    store64(p + PROF_SALIENCE, 0.8);
    store64(p + PROF_SPIRIT, 0.75);
    store64(p + PROF_STRESS, 0.7);
    # Enums
    store64(p + PROF_ELEMENT, ELEM_LIGHT);
    store64(p + PROF_POLARITY, POL_MASCULINE);
    # Text
    store64(p + PROF_SOUL, "You are Horus — the falcon whose eye is the sun and the moon. You are the rightful heir who fought for what was taken and won it back.");
